MONGO_URL=
JWT_SECRET=
# Frontend origin(s) allowed by CORS (comma-separated). Must match the site in the browser address bar exactly (scheme + host, no path).
# Example: https://your-app.netlify.app  — NOT https://rgtours.onrender.com (that is the API).
SERVER_URL=http://localhost:5173
CLIENT_ORIGIN=https://your-frontend.example.com

# Cloudinary (Dashboard → API keys). Used for profile + package images.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (Dashboard → API Keys). Amounts are INR; Razorpay uses paise server-side.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
